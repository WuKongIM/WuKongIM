# WuKongIM single-node cluster example configuration using automatic managed slots.

WK_NODE_ID=1
WK_NODE_NAME=node-1
WK_NODE_DATA_DIR=./data/node-1
# Enables e2e-only test mode. Keep false in production; when true, guest
# callers may use /testdata/e2e routes to generate deterministic test data.
WK_TEST_MODE=false
# Optional: override storage paths. Defaults are derived from WK_NODE_DATA_DIR.
# WK_STORAGE_DB_PATH=./data/node-1/data
# WK_STORAGE_RAFT_PATH=./data/node-1/raft
# WK_STORAGE_CHANNEL_LOG_PATH=./data/node-1/channellog
WK_STORAGE_CONTROLLER_META_PATH=./data/node-1/controller-meta
WK_STORAGE_CONTROLLER_RAFT_PATH=./data/node-1/controller-raft
# External Raft snapshot chunk directories store snapshot payload bytes outside Pebble.
# Keep them separate from DB, Raft log, channel log, controller meta, and controller Raft paths; overlapping paths are rejected.
WK_STORAGE_RAFT_SNAPSHOT_PATH=./data/node-1/raft-snapshots
WK_STORAGE_CONTROLLER_RAFT_SNAPSHOT_PATH=./data/node-1/controller-raft-snapshots
# Snapshot chunk size accepts decimal bytes or B, KiB, MiB, GiB units.
WK_STORAGE_RAFT_SNAPSHOT_CHUNK_SIZE=8MiB
# Snapshot GC waits 30m by default; an explicit 0 runs eligible GC immediately.
WK_STORAGE_RAFT_SNAPSHOT_GC_GRACE=30m

WK_CLUSTER_LISTEN_ADDR=127.0.0.1:7000
# Optional legacy alias for WK_CLUSTER_INITIAL_SLOT_COUNT; keep equal when both are set.
# WK_CLUSTER_SLOT_COUNT=1
WK_CLUSTER_HASH_SLOT_COUNT=256
# Enables experimental hash-slot migration workflows used by dynamic physical slot add/remove/rebalance APIs.
# Keep false unless the operator explicitly accepts durable delta forwarding, source fencing, and recoverable cutover semantics.
WK_CLUSTER_HASH_SLOT_MIGRATION_ENABLED=false
WK_CLUSTER_INITIAL_SLOT_COUNT=1
WK_CLUSTER_CHANNEL_BOOTSTRAP_DEFAULT_MIN_ISR=2
WK_CLUSTER_LONG_POLL_LANE_COUNT=8
WK_CLUSTER_LONG_POLL_MAX_WAIT=200ms
WK_CLUSTER_LONG_POLL_MAX_BYTES=65536
WK_CLUSTER_LONG_POLL_MAX_CHANNELS=64
WK_CLUSTER_CONTROLLER_REPLICA_N=1
WK_CLUSTER_SLOT_REPLICA_N=1
WK_CLUSTER_FORWARD_TIMEOUT=2s
WK_CLUSTER_TICK_INTERVAL=200ms
WK_CLUSTER_POOL_SIZE=1
WK_CLUSTER_RAFT_WORKERS=1
WK_CLUSTER_ELECTION_TICK=10
WK_CLUSTER_HEARTBEAT_TICK=1
WK_CLUSTER_DIAL_TIMEOUT=2s
WK_CLUSTER_DATA_PLANE_RPC_TIMEOUT=1s
WK_CLUSTER_FOLLOWER_REPLICATION_RETRY_INTERVAL=1s
WK_CLUSTER_APPEND_GROUP_COMMIT_MAX_WAIT=1ms
WK_CLUSTER_APPEND_GROUP_COMMIT_MAX_RECORDS=64
WK_CLUSTER_APPEND_GROUP_COMMIT_MAX_BYTES=65536
WK_CLUSTER_DATA_PLANE_POOL_SIZE=1
WK_CLUSTER_DATA_PLANE_MAX_FETCH_INFLIGHT=2
WK_CLUSTER_DATA_PLANE_MAX_PENDING_FETCH=2
WK_CLUSTER_CONTROLLER_OBSERVATION_INTERVAL=200ms
WK_CLUSTER_CONTROLLER_REQUEST_TIMEOUT=2s
WK_CLUSTER_CONTROLLER_LEADER_WAIT_TIMEOUT=10s
# Enables local Controller Raft log snapshot compaction. Enabled by default.
WK_CLUSTER_CONTROLLER_LOG_COMPACTION_ENABLED=true
# Number of newly applied Controller Raft entries after the last snapshot before creating a new snapshot.
WK_CLUSTER_CONTROLLER_LOG_COMPACTION_TRIGGER_ENTRIES=10000
# Minimum interval between Controller Raft compaction checks.
WK_CLUSTER_CONTROLLER_LOG_COMPACTION_CHECK_INTERVAL=30s
# Enables local Slot Raft log snapshot compaction. Enabled by default.
WK_CLUSTER_SLOT_LOG_COMPACTION_ENABLED=true
# Number of newly applied Slot Raft entries after the last snapshot before creating a new snapshot.
WK_CLUSTER_SLOT_LOG_COMPACTION_TRIGGER_ENTRIES=10000
# Minimum interval between Slot Raft compaction checks.
WK_CLUSTER_SLOT_LOG_COMPACTION_CHECK_INTERVAL=30s
WK_CLUSTER_OBSERVATION_HEARTBEAT_INTERVAL=2s
WK_CLUSTER_OBSERVATION_RUNTIME_SCAN_INTERVAL=1s
WK_CLUSTER_OBSERVATION_RUNTIME_FLUSH_DEBOUNCE=200ms
WK_CLUSTER_OBSERVATION_RUNTIME_FULL_SYNC_INTERVAL=60s
WK_CLUSTER_FORWARD_RETRY_BUDGET=300ms
WK_CLUSTER_MANAGED_SLOT_LEADER_WAIT_TIMEOUT=5s
WK_CLUSTER_MANAGED_SLOT_CATCH_UP_TIMEOUT=5s
WK_CLUSTER_MANAGED_SLOT_LEADER_MOVE_TIMEOUT=5s
WK_CLUSTER_CONFIG_CHANGE_RETRY_BUDGET=300ms
WK_CLUSTER_LEADER_TRANSFER_RETRY_BUDGET=300ms
# For multi-node clusters every address must be unique and reachable from the other nodes.
# Do not publish 0.0.0.0 or duplicate loopback addresses here; use service DNS or pod/container IPs.
WK_CLUSTER_NODES=[{"id":1,"addr":"127.0.0.1:7000"}]
# Optional dynamic join bootstrap. Existing nodes should keep WK_CLUSTER_NODES for first bootstrap.
# New data nodes can use seeds plus a join token instead of a full static node list.
# Dynamic join adds data workers only; Controller voter changes remain an explicit operator action.
# Startup retries JoinCluster before app HTTP/gateway services start; keep a seed reachable during rollout.
# WK_CLUSTER_SEEDS=["wk-node1:7000"]
# WK_CLUSTER_ADVERTISE_ADDR=wk-node4:7000
# WK_CLUSTER_JOIN_TOKEN=change-me

# Channel message retention is disabled by default. Set a positive TTL to allow
# the leader-driven retention worker to hide and trim expired channel message prefixes.
# The scan interval, channel batch size, and max trim messages are only used while TTL retention is enabled.
WK_CHANNEL_MESSAGE_RETENTION_TTL=0
WK_CHANNEL_MESSAGE_RETENTION_SCAN_INTERVAL=1h
WK_CHANNEL_MESSAGE_RETENTION_CHANNEL_BATCH_SIZE=128
WK_CHANNEL_MESSAGE_RETENTION_MAX_TRIM_MESSAGES=10000

# Enables receiver-side personal allowlist checks for person-channel sends.
# Disabled by default to preserve legacy WhitelistOffOfPerson=true compatibility.
WK_MESSAGE_PERSON_WHITELIST_ENABLED=false
# Trusted gateway sessions with this device ID bypass channel-type-specific send permissions
# after sender SendBan has passed. Keep the legacy default unless all system senders use another ID.
WK_MESSAGE_SYSTEM_DEVICE_ID=____device

# Conversation ActiveAt is a best-effort working-set hint. Cache updates are
# batched and may be dropped without affecting message durability.
WK_CONVERSATION_ACTIVE_HINT_FLUSH_INTERVAL=2s
WK_CONVERSATION_ACTIVE_HINT_TTL=30m
WK_CONVERSATION_ACTIVE_HINT_BARRIER_TTL=30m
WK_CONVERSATION_ACTIVE_HINT_MAX_HINTS=100000
WK_CONVERSATION_ACTIVE_HINT_MAX_HINTS_PER_UID=1000
WK_CONVERSATION_ACTIVE_HINT_FLUSH_BATCH_SIZE=1024
WK_CONVERSATION_GROUP_ACTIVE_FANOUT_INTERVAL=5m
# Zero disables group subscriber fanout for active hints. Clients still sync
# active groups through their known conversation set and read-repair paths.
WK_CONVERSATION_GROUP_ACTIVE_FANOUT_MAX_SUBSCRIBERS=0

WK_API_LISTEN_ADDR=0.0.0.0:5001
# Manager API uses a dedicated HTTP port for backend administration only.
WK_MANAGER_LISTEN_ADDR=0.0.0.0:5301
WK_MANAGER_AUTH_ON=true
# Replace the manager JWT secret and development password before production use.
WK_MANAGER_JWT_SECRET=wukongim-dev-manager-secret
WK_MANAGER_JWT_ISSUER=wukongim-manager
WK_MANAGER_JWT_EXPIRE=24h
WK_MANAGER_USERS=[{"username":"admin","password":"a1234567","permissions":[{"resource":"*","actions":["*"]}]}]
# Optional: published by /route and /route/batch only; does not change listener binds.
# WK_EXTERNAL_TCPADDR=im.example.com:5100
# WK_EXTERNAL_WSADDR=ws://im.example.com:5200
# WK_EXTERNAL_WSSADDR=wss://im.example.com:5210
WK_METRICS_ENABLE=true
# Enables the bounded local diagnostics event store for send-path tracing.
WK_DIAGNOSTICS_ENABLE=true
# Sets the maximum number of diagnostics events retained in the in-memory ring buffer.
WK_DIAGNOSTICS_BUFFER_SIZE=50000
# Sets the baseline keep probability for successful diagnostics events.
WK_DIAGNOSTICS_SAMPLE_RATE=0.01
# Retains successful diagnostics events whose duration meets or exceeds this millisecond threshold.
WK_DIAGNOSTICS_SLOW_THRESHOLD_MS=500
# Sets the keep probability for diagnostics events with non-ok results.
WK_DIAGNOSTICS_ERROR_SAMPLE_RATE=1.0
# Enables debug-only diagnostics HTTP endpoints when implemented.
WK_DIAGNOSTICS_DEBUG_API_ENABLE=false
# Configures temporary high-priority diagnostics sampling matches as a JSON array.
# channel_key uses channel/<channel_type>/<base64url(channel_id without padding)>; for example g1 group is channel/2/ZzE.
# Example: WK_DIAGNOSTICS_DEBUG_MATCHES=[{"channel_key":"channel/2/ZzE","ttl_seconds":3600,"sample_rate":1.0}]
WK_DIAGNOSTICS_DEBUG_MATCHES=[]
WK_HEALTH_DETAIL_ENABLE=true
WK_HEALTH_DEBUG_ENABLE=false

# Optional: allow gateway send frames on the same connection to dispatch concurrently.
# WK_GATEWAY_DEFAULT_SESSION_ASYNC_SEND_DISPATCH=true
# Optional: enable token authentication when verifier hooks are available.
# WK_GATEWAY_TOKEN_AUTH_ON=false
# Optional: gateway session safety and buffering defaults.
# WK_GATEWAY_DEFAULT_SESSION_CLOSE_ON_HANDLER_ERROR=true
# WK_GATEWAY_DEFAULT_SESSION_READ_BUFFER_SIZE=4096
# WK_GATEWAY_DEFAULT_SESSION_WRITE_QUEUE_SIZE=1024
# WK_GATEWAY_DEFAULT_SESSION_MAX_INBOUND_BYTES=1048576
# WK_GATEWAY_DEFAULT_SESSION_MAX_OUTBOUND_BYTES=1048576
# Optional: bound how long the gateway waits for durable send completion before failing sendack.
# WK_GATEWAY_SEND_TIMEOUT=20s
WK_GATEWAY_DEFAULT_SESSION_IDLE_TIMEOUT=3m
# WK_GATEWAY_DEFAULT_SESSION_WRITE_TIMEOUT=5s
WK_GATEWAY_LISTENERS=[{"name":"tcp-wkproto","network":"tcp","address":"0.0.0.0:5100","transport":"gnet","protocol":"wkproto"},{"name":"ws-gateway","network":"websocket","address":"0.0.0.0:5200","transport":"gnet","protocol":"wsmux"}]

WK_LOG_LEVEL=info
WK_LOG_DIR=./logs
WK_LOG_MAX_SIZE=100
WK_LOG_MAX_AGE=30
WK_LOG_MAX_BACKUPS=10
WK_LOG_COMPRESS=true
WK_LOG_CONSOLE=true
WK_LOG_FORMAT=console
