[node]
id = 1
data_dir = "./data/wukongim-single-node-data"

[cluster]
listen_addr = "127.0.0.1:7001"
id = "wukongim-single"
nodes = [{ id = 1, addr = "127.0.0.1:7001" }]
join_token = "change-me"
initial_slot_count = 1
hash_slot_count = 256
slot_replica_n = 1
node_health_report_interval = "5s"
node_health_report_ttl = "30s"
channel_reactor_count = 0
channel_store_append_workers = 0
channel_store_apply_workers = 0
channel_rpc_workers = 50
max_channels = 0
channel_append_batch_max_records = 0
channel_append_batch_max_wait = "0"
channel_follower_recovery_probe_interval = "2s"
channel_follower_recovery_probe_jitter = "1s"
commit_coordinator_flush_window = "200us"
commit_coordinator_max_requests = 0
commit_coordinator_max_records = 0
commit_coordinator_max_bytes = 0
commit_coordinator_shards = 0

[channel]
message_retention_physical_gc_enable = false
message_retention_scan_interval = "1m"
message_retention_channel_batch_size = 128
message_retention_max_trim_messages = 1000
message_retention_max_trim_bytes = 0
large_group_subscriber_threshold = 500

[api]
listen_addr = "127.0.0.1:5001"
external_tcp_addr = "127.0.0.1:5100"
external_ws_addr = "ws://127.0.0.1:5200"

[manager]
listen_addr = "127.0.0.1:5301"
auth_on = true
jwt_secret = "wukongim-dev-manager-secret"
jwt_issuer = "wukongim-manager"
jwt_expire = "24h"
users = [{ username = "admin", password = "a1234567", permissions = [{ resource = "*", actions = ["*"] }] }]

[bench]
api_enable = false
api_max_batch_size = 10000
api_max_payload_bytes = 10485760

[observability]
metrics_enable = true
debug_api_enable = false

[prometheus]
# Enable the app-managed Prometheus child process. Leave this false when an external Prometheus service is deployed.
enable = false
# Optional Prometheus HTTP API base URL used by manager realtime monitor queries; when empty, the manager uses listen_addr only if enable is true.
query_base_url = ""
# Optional external Prometheus binary path for the app-managed child process; empty uses the embedded binary.
binary_path = ""
# Prometheus web listen address for the app-managed child process and default manager query target when query_base_url is empty.
# Port 9099 avoids common local controller services that bind 9090.
listen_addr = "127.0.0.1:9099"
# Data directory for the generated Prometheus configuration and TSDB files used by the app-managed child process.
data_dir = "./data/wukongim-single-node-data/prometheus"
# Time-based retention window for the app-managed Prometheus TSDB.
retention_time = "360h"
# Optional size-based retention limit for the app-managed Prometheus TSDB; empty disables size retention.
retention_size = ""
# Scrape interval written into the app-managed Prometheus configuration.
scrape_interval = "15s"
# Metrics scrape targets for the app-managed Prometheus process, expressed as host:port values without a URL scheme.
scrape_targets = []

[top]
api_enable = true
collect_interval = "1s"
history_window = "5m"

[diagnostics]
enable = true
buffer_size = 50000
sample_rate = 0.01
slow_threshold_ms = 500
error_sample_rate = 1.0
deep_sample_rate = 0
deep_slow_threshold_ms = 500
deep_max_items_per_batch = 16
debug_matches = []

[log]
level = "info"
dir = "./data/wukongim-single-node-data/logs"
max_size = 100
max_age = 30
max_backups = 10
compress = true
console = true
format = "console"

[gateway]
listeners = [{ name = "tcp-wkproto", network = "tcp", address = "0.0.0.0:5100", transport = "gnet", protocol = "wkproto" }, { name = "ws-gateway", network = "websocket", address = "0.0.0.0:5200", transport = "gnet", protocol = "wsmux" }]
gnet_multicore = true
gnet_num_event_loop = 0
runtime_async_send_workers = 128
runtime_async_send_queue_capacity = 131072
runtime_async_auth_workers = 16
runtime_async_auth_queue_capacity = 8192
runtime_async_pool_release_timeout = "100ms"
default_session_async_send_batch_max_wait = "1ms"
default_session_async_send_batch_max_records = 512
default_session_async_send_batch_max_bytes = 524288
send_timeout = "5s"

[message]
person_whitelist_enabled = false
system_device_id = "____device"
permission_cache_ttl = "0"

[presence]
activation_timeout = "3s"
touch_flush_interval = "1s"
touch_batch_size = 512
# Maximum owner-local dirty routes processed across all touch chunks in one flush.
# Must be positive and greater than or equal to touch_batch_size.
touch_max_routes_per_flush = 65536
route_ttl = "90s"

[conversation]
max_last_message_concurrency = 32
authority_cache_max_rows_per_uid = 4096
authority_cache_max_rows = 100000
authority_list_db_window_max = 1000
authority_handoff_timeout = "3s"
authority_flush_interval = "1s"
authority_flush_timeout = "5s"
# Maximum dirty active rows persisted by one periodic, pressure-woken, or authority-handoff flush attempt.
authority_flush_batch_rows = 512
authority_admit_batch_rows = 512
authority_admit_concurrency = 16

[backup]
# Automatic cluster-semantic backup is disabled by default. Enabling it requires
# two distinct cross-region S3-compatible repositories plus external KMS keys.
enabled = false
# Recovery mode is mutually exclusive with automatic backup and keeps ordinary
# client/API traffic and side effects disabled until explicit activation.
restore_mode = false
# Stable logical identity shared by both repository copies.
repository_id = ""
# Stable generation of the live source cluster; required only when automatic backup is enabled.
source_generation = ""
# Fresh successor generation; required only in restore mode and must differ from the selected source.
target_generation = ""
# Absolute node-local directory for bounded temporary backup data.
staging_dir = ""
# External KMS identifiers; credentials come only from the provider credential chain.
kms_key_id = ""
signing_key_id = ""
# Previous signing keys retained for verification during key rotation; environment overrides use a JSON string list.
trusted_signing_key_ids = []
# Separate AWS-compatible role assumed only for version deletion during garbage collection.
garbage_collector_role_arn = ""
kms_region = ""
# Optional HTTPS KMS-compatible origin; empty uses the AWS regional endpoint.
kms_endpoint = ""
# Controller-Leader schedule reevaluation and cross-region recovery-point publication cadence.
incremental_interval = "1m"
restore_point_interval = "5m"
# Publish an independent daily baseline. The current implementation rematerializes source data; repository object-reuse optimization is a release gate.
synthetic_full_interval = "24h"
# Plaintext bytes per compressed-and-encrypted object (1 MiB through 256 MiB).
chunk_size_bytes = 8388608
# Hard node-local staging quota and bounded partition concurrency.
staging_max_bytes = 10737418240
max_parallel_partitions = 4
# Optional monthly materialized-full retention; zero disables this tier.
monthly_retention_months = 0
# Minimum compliance-mode Object Lock retention applied to every object.
object_lock_days = 7

[backup.primary]
# HTTPS S3-compatible API origin. The startup snapshot redacts this value.
endpoint = ""
region = ""
# The bucket must have versioning and Object Lock/WORM enabled for at least seven days.
bucket = ""
prefix = ""

[backup.secondary]
# This independently verified cross-region repository determines effective RPO.
endpoint = ""
region = ""
bucket = ""
prefix = ""


[delivery]
enable = true
fanout_page_size = 512
# Maximum recipients in one exact-target presence lookup and delivery plan.
# The same bound limits routes in each plan-wide owner-node push chunk.
push_batch_size = 512
pending_ack_ttl = "30s"
pending_ack_max_per_session = 1024
# Maximum recipient delivery plans waiting for asynchronous processing.
event_queue_size = 1024
# Maximum recipient-authority delivery batches processed concurrently by this node.
# This is independent from channel_append.recipient_authority_dispatch_concurrency.
recipient_worker_concurrency = 100

[channel_append]
shard_count = 0
advance_pool_size = 0
effect_pool_size = 0
recipient_authority_dispatch_concurrency = 0

[plugin]
enable = true
dir = "./data/wukongim-single-node-data/plugins"
socket_path = "./data/wukongim-single-node-data/run/plugin.sock"
sandbox_dir = "./data/wukongim-single-node-data/plugin-sandbox"
state_dir = "./data/wukongim-single-node-data/plugin-state"
timeout = "5s"
hot_reload = true
fail_open = false
persist_after_queue_size = 1024
persist_after_workers = 16
