# WuKongIM v2 static three-node cluster example: node 2.
#
# Start node1, node2, and node3 configs in separate terminals from the repo root.

# Stable non-zero node identity. This node must appear in WK_CLUSTER_NODES.
WK_NODE_ID=2

# Root data directory for clusterv2 controller, slot, and channel data.
WK_NODE_DATA_DIR=./data/wukongimv2-node-2

# Node-to-node clusterv2 RPC listen address advertised for node 2.
WK_CLUSTER_LISTEN_ADDR=127.0.0.1:7012

# Stable cluster identity shared by all nodes in this static cluster.
WK_CLUSTER_ID=wukongimv2-dev-three

# Static clusterv2 membership. Every node must use the same ordered node set.
WK_CLUSTER_NODES=[{"id":1,"addr":"127.0.0.1:7011"},{"id":2,"addr":"127.0.0.1:7012"},{"id":3,"addr":"127.0.0.1:7013"}]

# Physical Slot count created by the initial ControllerV2 snapshot.
# Three local nodes use one physical Slot per node to avoid a single metadata Raft group bottleneck.
WK_CLUSTER_INITIAL_SLOT_COUNT=3

# Logical hash-slot count used for routing channel keys to physical Slots.
WK_CLUSTER_HASH_SLOT_COUNT=16

# Desired Slot replica count. Three replicas require all three listed nodes.
WK_CLUSTER_SLOT_REPLICA_N=3

# ChannelV2 reactor partitions. 0 derives max(4, GOMAXPROCS).
WK_CLUSTER_CHANNEL_REACTOR_COUNT=0

# Blocking ChannelV2 worker caps. 0 keeps the runtime default.
WK_CLUSTER_CHANNEL_STORE_APPEND_WORKERS=0
WK_CLUSTER_CHANNEL_STORE_APPLY_WORKERS=0
WK_CLUSTER_CHANNEL_RPC_WORKERS=50

# Maximum loaded ChannelV2 runtimes on this node. 0 keeps unlimited behavior.
WK_CLUSTER_MAX_CHANNELS=0

# ChannelV2 append batch flush controls. 0 keeps the runtime default.
WK_CLUSTER_CHANNEL_APPEND_BATCH_MAX_RECORDS=0
WK_CLUSTER_CHANNEL_APPEND_BATCH_MAX_WAIT=0

# Parked follower recovery probe base interval and deterministic jitter.
# Keep interval+jitter below WK_GATEWAY_SEND_TIMEOUT so lost hints recover before sendack timeout.
WK_CLUSTER_CHANNEL_FOLLOWER_RECOVERY_PROBE_INTERVAL=2s
WK_CLUSTER_CHANNEL_FOLLOWER_RECOVERY_PROBE_JITTER=1s

# Maximum time to collect adjacent ChannelV2 append requests before one durable fsync.
WK_CLUSTER_COMMIT_COORDINATOR_FLUSH_WINDOW=200us
# Optional caps for one grouped physical commit. 0 keeps the limit unbounded.
WK_CLUSTER_COMMIT_COORDINATOR_MAX_REQUESTS=0
WK_CLUSTER_COMMIT_COORDINATOR_MAX_RECORDS=0
WK_CLUSTER_COMMIT_COORDINATOR_MAX_BYTES=0
WK_CLUSTER_COMMIT_COORDINATOR_SHARDS=0

# Optional HTTP API listener for /healthz, /readyz, metrics, and bench/v1.
WK_API_LISTEN_ADDR=127.0.0.1:5012

# Dedicated manager HTTP API listener for /manager/login.
WK_MANAGER_LISTEN_ADDR=127.0.0.1:5312
WK_MANAGER_AUTH_ON=true
# Replace the manager JWT secret and development password before production use.
WK_MANAGER_JWT_SECRET=wukongim-dev-manager-secret
WK_MANAGER_JWT_ISSUER=wukongim-manager
WK_MANAGER_JWT_EXPIRE=24h
WK_MANAGER_USERS=[{"username":"admin","password":"a1234567","permissions":[{"resource":"*","actions":["*"]}]}]

# Benchmark-only HTTP API surface for controlled local or lab environments.
WK_BENCH_API_ENABLE=true

# Bench API request limits.
WK_BENCH_API_MAX_BATCH_SIZE=10000
WK_BENCH_API_MAX_PAYLOAD_BYTES=10485760

# Prometheus metrics and debug API toggles on the API listener.
WK_METRICS_ENABLE=true
# Optional app-managed Prometheus process. It requires WK_METRICS_ENABLE=true and scrapes this node's /metrics endpoint.
WK_PROMETHEUS_ENABLE=false
WK_PROMETHEUS_BINARY_PATH=
WK_PROMETHEUS_LISTEN_ADDR=127.0.0.1:9092
WK_PROMETHEUS_DATA_DIR=./data/wukongimv2-node-2/prometheus
WK_PROMETHEUS_RETENTION_TIME=360h
WK_PROMETHEUS_RETENTION_SIZE=
WK_PROMETHEUS_SCRAPE_INTERVAL=15s
# Leave empty to derive one target from WK_API_LISTEN_ADDR, or set a JSON string list of host:port targets.
WK_PROMETHEUS_SCRAPE_TARGETS=[]
# WK_DEBUG_API_ENABLE exposes all local /debug endpoints, including pprof, config, cluster, and diagnostics query routes.
WK_DEBUG_API_ENABLE=false
# Read-only node-local operations snapshot used by wkcli top. This does not require WK_METRICS_ENABLE.
WK_TOP_API_ENABLE=true
# Sampling cadence for the top collector.
WK_TOP_COLLECT_INTERVAL=1s
# In-memory history retained for top window queries.
WK_TOP_HISTORY_WINDOW=5m

# Local SEND diagnostics. Sampling keeps the hot path bounded; disable in ultra-low overhead runs.
WK_DIAGNOSTICS_ENABLE=true
WK_DIAGNOSTICS_BUFFER_SIZE=50000
WK_DIAGNOSTICS_SAMPLE_RATE=0.01
WK_DIAGNOSTICS_SLOW_THRESHOLD_MS=500
WK_DIAGNOSTICS_ERROR_SAMPLE_RATE=1.0
# WK_DIAGNOSTICS_DEEP_SAMPLE_RATE controls expensive ChannelV2 reactor/store detail sampling for ordinary successful events; 0 disables ordinary deep detail.
WK_DIAGNOSTICS_DEEP_SAMPLE_RATE=0
# WK_DIAGNOSTICS_DEEP_SLOW_THRESHOLD_MS keeps bounded deep trace detail for slow reactor/store stages; defaults to WK_DIAGNOSTICS_SLOW_THRESHOLD_MS.
WK_DIAGNOSTICS_DEEP_SLOW_THRESHOLD_MS=500
# WK_DIAGNOSTICS_DEEP_MAX_ITEMS_PER_BATCH bounds how many traced items one deep ChannelV2 batch expands.
WK_DIAGNOSTICS_DEEP_MAX_ITEMS_PER_BATCH=16
# Optional temporary high-priority sampling rules. List fields use one JSON string value.
WK_DIAGNOSTICS_DEBUG_MATCHES=[]

# Rolling application logs. Console and compression default true when unset.
WK_LOG_LEVEL=info
WK_LOG_DIR=./data/wukongimv2-node-2/logs
WK_LOG_MAX_SIZE=100
WK_LOG_MAX_AGE=30
WK_LOG_MAX_BACKUPS=10
WK_LOG_COMPRESS=true
WK_LOG_CONSOLE=true
WK_LOG_FORMAT=console

# Published gateway addresses returned by bench capacity discovery.
WK_EXTERNAL_TCPADDR=127.0.0.1:5112
WK_EXTERNAL_WSADDR=ws://127.0.0.1:5212

# Client-facing gateway listeners. List fields use one JSON string value.
WK_GATEWAY_LISTENERS=[{"name":"tcp-wkproto","network":"tcp","address":"127.0.0.1:5112","transport":"gnet","protocol":"wkproto"},{"name":"ws-gateway","network":"websocket","address":"127.0.0.1:5212","transport":"gnet","protocol":"wsmux"}]

# Optional gnet event-loop tuning. 0 keeps the CPU-aware cmd/wukongimv2 default.
WK_GATEWAY_GNET_MULTICORE=true
WK_GATEWAY_GNET_NUM_EVENT_LOOP=0

# Gateway SEND async sharding and micro-batch collection controls.
WK_GATEWAY_RUNTIME_ASYNC_SEND_WORKERS=128
WK_GATEWAY_RUNTIME_ASYNC_SEND_QUEUE_CAPACITY=131072
WK_GATEWAY_RUNTIME_ASYNC_AUTH_WORKERS=16
WK_GATEWAY_RUNTIME_ASYNC_AUTH_QUEUE_CAPACITY=8192
WK_GATEWAY_RUNTIME_ASYNC_POOL_RELEASE_TIMEOUT=100ms
WK_GATEWAY_DEFAULT_SESSION_ASYNC_SEND_BATCH_MAX_WAIT=1ms
WK_GATEWAY_DEFAULT_SESSION_ASYNC_SEND_BATCH_MAX_RECORDS=512
WK_GATEWAY_DEFAULT_SESSION_ASYNC_SEND_BATCH_MAX_BYTES=524288

# Per-SEND timeout used by the gateway adapter.
WK_GATEWAY_SEND_TIMEOUT=5s

# Message permission checks.
# Enables receiver-side personal allowlist enforcement; disabled by default for legacy compatibility.
WK_MESSAGE_PERSON_WHITELIST_ENABLED=false
# Trusted device id that bypasses channel-specific send permissions after sender SendBan passes.
WK_MESSAGE_SYSTEM_DEVICE_ID=____device
# TTL for the bounded send-permission read cache. Zero disables caching.
WK_MESSAGE_PERMISSION_CACHE_TTL=0

# Presence route activation, owner touch batching, and authority TTL.
WK_PRESENCE_ACTIVATION_TIMEOUT=3s
WK_PRESENCE_TOUCH_FLUSH_INTERVAL=1s
WK_PRESENCE_TOUCH_BATCH_SIZE=512
WK_PRESENCE_ROUTE_TTL=90s

# Conversation authority and list-read tuning.
# Bounds concurrent channel tail reads used to hydrate one /conversation/list page.
WK_CONVERSATION_MAX_LAST_MESSAGE_CONCURRENCY=32
# Conversation authority cache, handoff, and admission controls.
WK_CONVERSATION_AUTHORITY_CACHE_MAX_ROWS_PER_UID=4096
WK_CONVERSATION_AUTHORITY_CACHE_MAX_ROWS=100000
WK_CONVERSATION_AUTHORITY_LIST_DB_WINDOW_MAX=1000
WK_CONVERSATION_AUTHORITY_HANDOFF_TIMEOUT=3s
WK_CONVERSATION_AUTHORITY_FLUSH_INTERVAL=1s
WK_CONVERSATION_AUTHORITY_FLUSH_BATCH_ROWS=512
WK_CONVERSATION_AUTHORITY_ADMIT_BATCH_ROWS=512
WK_CONVERSATION_AUTHORITY_ADMIT_CONCURRENCY=16

# Channel management marks ordinary group channels large when subscriber count exceeds this threshold.
WK_CHANNEL_LARGE_GROUP_SUBSCRIBER_THRESHOLD=500

# Online delivery fanout and owner-local recvack tracking are enabled by default; set false to disable them.
WK_DELIVERY_ENABLE=true
# Channel append shard count controls channel-key authority-state lookup shards; zero derives a CPU-aware default.
WK_CHANNEL_APPEND_SHARD_COUNT=0
# Channel append advance pool size is the direct ants pool capacity used to activate writer state machines; zero derives a CPU-aware default.
WK_CHANNEL_APPEND_ADVANCE_POOL_SIZE=0
# Channel append effect pool size is the direct ants pool capacity shared by blocking append calls and post-append recipient effects; zero derives a CPU-aware default.
WK_CHANNEL_APPEND_EFFECT_POOL_SIZE=0
# Channel append recipient authority dispatch concurrency bounds per-message recipient-authority fanout after append; zero uses the bounded default.
WK_CHANNEL_APPEND_RECIPIENT_AUTHORITY_DISPATCH_CONCURRENCY=0
WK_DELIVERY_FANOUT_PAGE_SIZE=512
WK_DELIVERY_PUSH_BATCH_SIZE=512
WK_DELIVERY_PENDING_ACK_TTL=30s
WK_DELIVERY_PENDING_ACK_MAX_PER_SESSION=1024
WK_DELIVERY_EVENT_QUEUE_SIZE=1024
