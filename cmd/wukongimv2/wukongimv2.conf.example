# WuKongIM v2 standalone verification config.
#
# This file only uses keys currently parsed by cmd/wukongimv2. It starts one
# node as a single-node cluster for the phase-1 SEND -> SENDACK path.

# Stable non-zero node identity. Message IDs are seeded from this value.
WK_NODE_ID=1

# Root data directory for clusterv2 controller, slot, and channel data.
WK_NODE_DATA_DIR=./data/wukongimv2-node-1

# Node-to-node clusterv2 RPC listen address. Keep it reachable by this node.
WK_CLUSTER_LISTEN_ADDR=127.0.0.1:7001

# Stable cluster identity shared by every node in this clusterv2 cluster.
WK_CLUSTER_ID=wukongimv2-single

# Static clusterv2 membership. This single-node cluster lists only itself.
WK_CLUSTER_NODES=[{"id":1,"addr":"127.0.0.1:7001"}]

# Physical Slot count created by the initial ControllerV2 snapshot.
WK_CLUSTER_INITIAL_SLOT_COUNT=1

# Logical hash-slot count used for routing channel keys to physical Slots.
WK_CLUSTER_HASH_SLOT_COUNT=16

# Desired Slot replica count for this single-node cluster.
WK_CLUSTER_SLOT_REPLICA_N=1

# ChannelV2 reactor partitions. 0 derives max(4, GOMAXPROCS).
WK_CLUSTER_CHANNEL_REACTOR_COUNT=0

# Maximum loaded ChannelV2 runtimes on this node. 0 keeps unlimited behavior.
WK_CLUSTER_MAX_CHANNELS=0

# ChannelV2 append batch flush controls. 0 keeps the runtime default.
WK_CLUSTER_CHANNEL_APPEND_BATCH_MAX_RECORDS=0
WK_CLUSTER_CHANNEL_APPEND_BATCH_MAX_WAIT=0

# Parked follower recovery probe base interval and deterministic jitter.
# Keep interval+jitter below WK_GATEWAY_SEND_TIMEOUT so lost hints recover before sendack timeout.
WK_CLUSTER_CHANNEL_FOLLOWER_RECOVERY_PROBE_INTERVAL=2s
WK_CLUSTER_CHANNEL_FOLLOWER_RECOVERY_PROBE_JITTER=1s

# Maximum time to collect adjacent ChannelV2 append requests before one durable fsync.
WK_CLUSTER_COMMIT_COORDINATOR_FLUSH_WINDOW=200us
# Optional caps for one grouped physical commit. 0 keeps the limit unbounded.
WK_CLUSTER_COMMIT_COORDINATOR_MAX_REQUESTS=0
WK_CLUSTER_COMMIT_COORDINATOR_MAX_RECORDS=0
WK_CLUSTER_COMMIT_COORDINATOR_MAX_BYTES=0

# Optional HTTP API listener for /healthz, /readyz, metrics, and bench/v1.
WK_API_LISTEN_ADDR=127.0.0.1:5001

# Benchmark-only HTTP API surface for controlled local or lab environments.
WK_BENCH_API_ENABLE=true

# Bench API request limits.
WK_BENCH_API_MAX_BATCH_SIZE=10000
WK_BENCH_API_MAX_PAYLOAD_BYTES=10485760

# Prometheus metrics and pprof toggles on the API listener.
WK_METRICS_ENABLE=true
WK_PPROF_ENABLE=false

# Published gateway addresses returned by bench capacity discovery.
WK_EXTERNAL_TCPADDR=127.0.0.1:5100
WK_EXTERNAL_WSADDR=ws://127.0.0.1:5200

# Client-facing gateway listeners. List fields use one JSON string value.
WK_GATEWAY_LISTENERS=[{"name":"tcp-wkproto","network":"tcp","address":"0.0.0.0:5100","transport":"gnet","protocol":"wkproto"},{"name":"ws-gateway","network":"websocket","address":"0.0.0.0:5200","transport":"gnet","protocol":"wsmux"}]

# Optional gnet event-loop tuning. 0 keeps the CPU-aware cmd/wukongimv2 default.
WK_GATEWAY_GNET_MULTICORE=true
WK_GATEWAY_GNET_NUM_EVENT_LOOP=0

# Gateway SEND async sharding and micro-batch collection controls.
WK_GATEWAY_DEFAULT_SESSION_ASYNC_SEND_DISPATCH_WORKERS=0
WK_GATEWAY_DEFAULT_SESSION_ASYNC_SEND_BATCH_MAX_WAIT=1ms
WK_GATEWAY_DEFAULT_SESSION_ASYNC_SEND_BATCH_MAX_RECORDS=512
WK_GATEWAY_DEFAULT_SESSION_ASYNC_SEND_BATCH_MAX_BYTES=524288

# Per-SEND timeout used by the gateway adapter.
WK_GATEWAY_SEND_TIMEOUT=5s

# Presence route activation, owner touch batching, and authority TTL.
WK_PRESENCE_ACTIVATION_TIMEOUT=3s
WK_PRESENCE_TOUCH_FLUSH_INTERVAL=1s
WK_PRESENCE_TOUCH_BATCH_SIZE=512
WK_PRESENCE_ROUTE_TTL=90s

# Optional online delivery fanout and owner-local recvack tracking.
WK_DELIVERY_ENABLE=false
WK_DELIVERY_FANOUT_PAGE_SIZE=512
WK_DELIVERY_PUSH_BATCH_SIZE=512
WK_DELIVERY_PENDING_ACK_TTL=30s
WK_DELIVERY_PENDING_ACK_MAX_PER_SESSION=1024
WK_DELIVERY_EVENT_QUEUE_SIZE=1024
